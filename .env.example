DATABASE_URL=sqlite+aiosqlite:///./agentq.db

# API authentication — required whenever ENVIRONMENT is not "local" (the
# Docker default sets ENVIRONMENT=production). Generate each with:
#   openssl rand -hex 32
ADMIN_API_KEY=
VIEWER_API_KEY=
INGEST_API_KEY=

# Rate limiting (requests per key per minute; in-memory, per-process)
RATE_LIMIT_PER_MINUTE=120

# Privacy-safe product analytics. User IDs are only retained as HMAC hashes
# when a private random salt is configured. Leave blank for anonymous events.
PRODUCT_ANALYTICS_ENABLED=true
PRODUCT_ANALYTICS_IDENTITY_SALT=
PRODUCT_ANALYTICS_RETENTION_DAYS=90

# Baked into the frontend build at build time (Next.js inlines NEXT_PUBLIC_*
# vars — set this before `docker compose build`, not just before `up`).
# Use the same value as ADMIN_API_KEY above so the dashboard has full access.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_API_KEY=

# Demo mode — seeds realistic sample data on startup into a SEPARATE database
# file (DEMO_DATABASE_URL), so demo data can never appear when DEMO_MODE=false.
DEMO_MODE=false
DEMO_DATABASE_URL=sqlite+aiosqlite:///./agentq_demo.db

JUDGE_MODEL=claude-sonnet-4-6     # used for LLM rubric generation
# Optional — your own key, your own cost. AgentQ never bundles or shares a
# key; if empty, rubric generation is skipped (everything else works
# normally). Can also be set later via the Settings page.
ANTHROPIC_API_KEY=

# Legacy webhook (always fires on violations)
WEBHOOK_ENABLED=false
WEBHOOK_URL=

# Behavior clustering
BEHAVIOR_SIMILARITY_THRESHOLD=0.82   # cosine similarity threshold (0–1)

# Slack alerts
SLACK_WEBHOOK_URL=

# Email alerts (aiosmtplib)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_TO=

# Circuit breakers and anomaly thresholds
MAX_AGENT_STEPS=50
MAX_MODEL_CALLS=20
MAX_TOOL_CALLS=30
MAX_RETRIES=5
MAX_RUNTIME_SECONDS=300
MAX_TOKENS_PER_RUN=100000
MAX_COST_USD_PER_RUN=10
MAX_SIMILAR_TOOL_CALLS=5
UNUSUAL_COST_USD=5
UNUSUAL_LATENCY_MS=30000
UNUSUAL_OUTPUT_TOKENS=8000
MAX_SIMILAR_MODEL_CALLS=3
CHEAP_TASK_TOKEN_THRESHOLD=300
TREND_CHECK_INTERVAL_SECONDS=300
TREND_WINDOW_MINUTES=15
TREND_BASELINE_MINUTES=60
TREND_SPIKE_MULTIPLIER=2.0
TREND_MIN_RUNS=5
RETENTION_INTERVAL_SECONDS=3600
APPROVAL_REQUIRED_TOOLS=send_email,delete,delete_file,drop_table,update_production,make_purchase,publish,change_permissions,privileged_exec
